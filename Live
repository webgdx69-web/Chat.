<script>
    // ============ STATE MANAGEMENT ============
    const state = {
        currentUser: null,
        selectedContact: null,
        messages: {},
        users: [],
        isAdmin: false,
        localStream: null,
        remoteStream: null,
        micEnabled: true,
        videoEnabled: true,
        callActive: false,
        watchPartyMessages: [],
        friendRequests: [],
        sentInvites: [],
        pendingCalls: {},
        userProfiles: {}
    };

    // Initialize app
    window.addEventListener('DOMContentLoaded', () => {
        loadFromStorage();
        setupEventListeners();
    });

    // ============ STORAGE MANAGEMENT ============
    function saveToStorage() {
        localStorage.setItem('friendchat_users', JSON.stringify(state.users));
        localStorage.setItem('friendchat_messages', JSON.stringify(state.messages));
        localStorage.setItem('friendchat_friendRequests', JSON.stringify(state.friendRequests));
        localStorage.setItem('friendchat_userProfiles', JSON.stringify(state.userProfiles));
    }

    function loadFromStorage() {
        const users = localStorage.getItem('friendchat_users');
        const messages = localStorage.getItem('friendchat_messages');
        const friendRequests = localStorage.getItem('friendchat_friendRequests');
        const userProfiles = localStorage.getItem('friendchat_userProfiles');
        
        if (users) state.users = JSON.parse(users);
        if (messages) state.messages = JSON.parse(messages);
        if (friendRequests) state.friendRequests = JSON.parse(friendRequests);
        if (userProfiles) state.userProfiles = JSON.parse(userProfiles);

        const currentUser = localStorage.getItem('friendchat_currentUser');
        if (currentUser) {
            state.currentUser = JSON.parse(currentUser);
            goToChat();
        }
    }

    function setupEventListeners() {
        document.getElementById('messageInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });
    }

    // ============ AUTH FUNCTIONS ============
    function toggleForm() {
        document.getElementById('loginForm').classList.toggle('hidden');
        document.getElementById('signupForm').classList.toggle('hidden');
    }

    function signup() {
        const name = document.getElementById('signupName').value.trim();
        const email = document.getElementById('signupEmail').value.trim();
        const password = document.getElementById('signupPassword').value;
        const confirmPassword = document.getElementById('signupConfirmPassword').value;

        if (!name || !email || !password) {
            alert('Please fill all fields');
            return;
        }

        if (password !== confirmPassword) {
            alert('Passwords do not match');
            return;
        }

        if (state.users.some(u => u.email === email)) {
            alert('Email already registered');
            return;
        }

        const newUser = {
            id: Date.now(),
            name,
            email,
            password, // In production, this should be hashed
            approved: false,
            avatar: name.charAt(0).toUpperCase()
        };

        state.users.push(newUser);
        saveToStorage();

        alert('Account created! Waiting for admin approval.');
        toggleForm();
        document.getElementById('signupName').value = '';
        document.getElementById('signupEmail').value = '';
        document.getElementById('signupPassword').value = '';
        document.getElementById('signupConfirmPassword').value = '';
    }

    function login() {
        const email = document.getElementById('loginEmail').value.trim();
        const password = document.getElementById('loginPassword').value;

        const user = state.users.find(u => u.email === email && u.password === password);

        if (!user) {
            alert('Invalid email or password');
            return;
        }

        if (!user.approved && email !== 'admin@friendchat.com') {
            alert('Your account is pending admin approval');
            return;
        }

        // Check if admin
        if (email === 'admin@friendchat.com') {
            state.isAdmin = true;
            goToAdmin();
        } else {
            state.currentUser = user;
            localStorage.setItem('friendchat_currentUser', JSON.stringify(user));
            goToChat();
        }

        document.getElementById('loginEmail').value = '';
        document.getElementById('loginPassword').value = '';
    }

    // ============ ADMIN PANEL ============
    function goToAdmin() {
        document.getElementById('authPage').classList.add('hidden');
        document.getElementById('adminPage').classList.remove('hidden');
        document.getElementById('adminUser').textContent = 'Admin Panel';
        updateAdminPanel();
    }

    function updateAdminPanel() {
        const pendingUsers = state.users.filter(u => !u.approved);
        const approvedUsers = state.users.filter(u => u.approved);

        document.getElementById('pendingUsersList').innerHTML = pendingUsers.length 
            ? pendingUsers.map(user => `
                <div class="user-card">
                    <div class="user-info">
                        <div class="user-name">${user.name}</div>
                        <div class="user-email">${user.email}</div>
                    </div>
                    <div class="user-actions">
                        <button class="btn-small btn-approve" onclick="approveUser(${user.id})">Approve</button>
                        <button class="btn-small btn-reject" onclick="rejectUser(${user.id})">Reject</button>
                    </div>
                </div>
            `).join('')
            : '<p style="opacity: 0.7;">No pending users</p>';

        document.getElementById('approvedUsersList').innerHTML = approvedUsers.length
            ? approvedUsers.map(user => `
                <div class="user-card">
                    <div class="user-info">
                        <div class="user-name">${user.name}</div>
                        <div class="user-email">${user.email}</div>
                    </div>
                    <div style="color: var(--success);">✓ Approved</div>
                </div>
            `).join('')
            : '<p style="opacity: 0.7;">No approved users</p>';
    }

    function approveUser(userId) {
        const user = state.users.find(u => u.id === userId);
        if (user) {
            user.approved = true;
            saveToStorage();
            updateAdminPanel();
            alert(`User ${user.name} has been approved!`);
        }
    }

    function rejectUser(userId) {
        state.users = state.users.filter(u => u.id !== userId);
        saveToStorage();
        updateAdminPanel();
        alert('User has been rejected and removed.');
    }

    function showAdminSection(section) {
        document.getElementById('pendingUsersSection').classList.toggle('hidden', section !== 'pending');
        document.getElementById('approvedUsersSection').classList.toggle('hidden', section !== 'approved');
    }

    function logoutAdmin() {
        state.isAdmin = false;
        document.getElementById('authPage').classList.remove('hidden');
        document.getElementById('adminPage').classList.add('hidden');
        document.getElementById('loginEmail').value = '';
        document.getElementById('loginPassword').value = '';
    }

    // ============ CHAT PAGE ============
    function goToChat() {
        document.getElementById('authPage').classList.add('hidden');
        document.getElementById('chatPage').classList.remove('hidden');
        
        document.getElementById('userAvatarChat').textContent = state.currentUser.avatar;
        document.getElementById('chatUserName').textContent = state.currentUser.name;
        
        updateContactsList();
        if (state.users.some(u => u.approved && u.id !== state.currentUser.id)) {
            selectContact(state.users.find(u => u.approved && u.id !== state.currentUser.id));
        }
    }

    function updateContactsList() {
        const contacts = state.users.filter(u => u.approved && u.id !== state.currentUser.id);
        document.getElementById('contactsList').innerHTML = contacts.map(contact => `
            <div class="contact-item ${state.selectedContact?.id === contact.id ? 'active' : ''}" onclick="selectContact({id: ${contact.id}, name: '${contact.name}', avatar: '${contact.avatar}'})">
                <div class="contact-name">${contact.name}</div>
                <div class="contact-status">Online</div>
            </div>
        `).join('');
    }

    // ============ MESSAGE FUNCTIONS ============
    function selectContact(contact) {
        state.selectedContact = contact;
        document.getElementById('chatContactName').textContent = contact.name;
        updateContactsList();
        loadMessages();
    }

    function loadMessages() {
        if (!state.selectedContact) return;
        
        const key = `chat_${state.currentUser.id}_${state.selectedContact.id}`;
        const messages = state.messages[key] || [];
        
        const messagesHtml = messages.map(msg => `
            <div class="message ${msg.sender === state.currentUser.id ? 'own' : 'other'}">
                <div class="message-content">${msg.text}</div>
            </div>
        `).join('');

        document.getElementById('messagesArea').innerHTML = messagesHtml;
        document.getElementById('messagesArea').scrollTop = document.getElementById('messagesArea').scrollHeight;
    }

    function sendMessage() {
        const input = document.getElementById('messageInput');
        const text = input.value.trim();

        if (!text || !state.selectedContact) return;

        const key = `chat_${state.currentUser.id}_${state.selectedContact.id}`;
        if (!state.messages[key]) state.messages[key] = [];

        state.messages[key].push({
            sender: state.currentUser.id,
            text,
            timestamp: new Date().getTime()
        });

        saveToStorage();
        input.value = '';
        loadMessages();
    }

    // Demo: Create default admin account if it doesn't exist
    if (!state.users.some(u => u.email === 'admin@friendchat.com')) {
        state.users.push({
            id: 1,
            name: 'Admin',
            email: 'admin@friendchat.com',
            password: 'admin123',
            approved: true,
            avatar: 'A'
        });
        saveToStorage();
    }


    function endCall() {
        document.getElementById('videoModal').classList.remove('active');
        
        if (state.localStream) {
            state.localStream.getTracks().forEach(track => track.stop());
            state.localStream = null;
        }
        
        state.callActive = false;
        state.micEnabled = true;
        state.videoEnabled = true;
        
        document.getElementById('btnMic').classList.add('active');
        document.getElementById('btnVideo').classList.add('active');
    }

    function toggleMic() {
        if (!state.localStream && !state.callActive) {
            navigator.mediaDevices.getUserMedia({ audio: true })
                .then(stream => {
                    state.localStream = stream;
                    state.micEnabled = true;
                    document.getElementById('btnMic').classList.add('active');
                })
                .catch(err => alert('Microphone access denied'));
            return;
        }

        if (state.localStream) {
            state.micEnabled = !state.micEnabled;
            state.localStream.getAudioTracks().forEach(track => {
                track.enabled = state.micEnabled;
            });
            document.getElementById('btnMic').classList.toggle('active');
        }
    }

    function toggleVideo() {
        if (!state.callActive) {
            navigator.mediaDevices.getUserMedia({ video: true })
                .then(stream => {
                    state.localStream = stream;
                    state.videoEnabled = true;
                    document.getElementById('btnVideo').classList.add('active');
                })
                .catch(err => alert('Camera access denied'));
            return;
        }

        if (state.localStream) {
            state.videoEnabled = !state.videoEnabled;
            state.localStream.getVideoTracks().forEach(track => {
                track.enabled = state.videoEnabled;
            });
            document.getElementById('btnVideo').classList.toggle('active');
        }
    }

    function toggleCallMic() {
        if (state.localStream) {
            state.micEnabled = !state.micEnabled;
            state.localStream.getAudioTracks().forEach(track => {
                track.enabled = state.micEnabled;
            });
            document.getElementById('videoCallMicBtn').classList.toggle('inactive');
        }
    }

    function toggleCallVideo() {
        if (state.localStream) {
            state.videoEnabled = !state.videoEnabled;
            state.localStream.getVideoTracks().forEach(track => {
                track.enabled = state.videoEnabled;
            });
            document.getElementById('videoCallVideoBtn').classList.toggle('inactive');
        }
    }

    function shareScreen() {
        if (!state.callActive) {
            alert('Start a call first');
            return;
        }

        navigator.mediaDevices.getDisplayMedia({
            video: true,
            audio: false
        })
        .then(stream => {
            document.getElementById('screenShareBox').classList.remove('hidden');
            document.getElementById('screenVideo').srcObject = stream;
        })
        .catch(err => {
            if (err.name !== 'NotAllowedError') {
                alert('Screen sharing failed: ' + err.message);
            }
        });
    }

    function shareScreenInCall() {
        shareScreen();
    }

    // ============ WATCH PARTY ============
    function openWatchParty() {
        if (!state.selectedContact) {
            alert('Select a contact first');
            return;
        }
        document.getElementById('watchPartyPage').classList.remove('hidden');
        document.getElementById('chatPage').classList.add('hidden');
    }

    function closeWatchParty() {
        document.getElementById('watchPartyPage').classList.add('hidden');
        document.getElementById('chatPage').classList.remove('hidden');
    }

    function loadVideo(event) {
        const file = event.target.files[0];
        if (file) {
            const url = URL.createObjectURL(file);
            document.getElementById('watchVideo').src = url;
        }
    }

    function playVideo() {
        document.getElementById('watchVideo').play();
    }

    function pauseVideo() {
        document.getElementById('watchVideo').pause();
    }

    function sendWatchMessage() {
        const input = document.getElementById('watchMessageInput');
        const text = input.value.trim();

        if (!text) return;

        state.watchPartyMessages.push({
            user: state.currentUser.name,
            text,
            timestamp: new Date().getTime()
        });

        updateWatchMessages();
        input.value = '';
    }

    function updateWatchMessages() {
        document.getElementById('watchMessages').innerHTML = state.watchPartyMessages
            .slice(-50)
            .map(msg => `
                <div class="watch-message">
                    <div class="watch-message-user">${msg.user}</div>
                    <div>${msg.text}</div>
                </div>
            `).join('');
        document.getElementById('watchMessages').scrollTop = document.getElementById('watchMessages').scrollHeight;
    }

    // ============ LOGOUT ============
    function logout() {
        state.currentUser = null;
        state.selectedContact = null;
        localStorage.removeItem('friendchat_currentUser');
        
        if (state.localStream) {
            state.localStream.getTracks().forEach(track => track.stop());
        }

        document.getElementById('chatPage').classList.add('hidden');
        document.getElementById('authPage').classList.remove('hidden');
        document.getElementById('loginEmail').value = '';
        document.getElementById('loginPassword').value = '';
    }

    // ============ PROFILE FUNCTIONS ============
    function openProfileModal() {
        const profile = state.userProfiles[state.currentUser.id] || {
            bio: '',
            status: 'Online',
            avatar: state.currentUser.avatar
        };

        document.getElementById('profileAvatarDisplay').textContent = profile.avatar;
        document.getElementById('avatarInput').value = '';
        document.getElementById('profileName').value = state.currentUser.name;
        document.getElementById('profileEmail').value = state.currentUser.email;
        document.getElementById('profileBio').value = profile.bio;
        document.getElementById('profileStatus').value = profile.status;

        document.getElementById('profileModal').classList.add('active');
    }

    function closeProfileModal() {
        document.getElementById('profileModal').classList.remove('active');
    }

    function updateAvatar() {
        const input = document.getElementById('avatarInput').value.trim();
        if (input) {
            const avatar = input.charAt(0).toUpperCase();
            document.getElementById('profileAvatarDisplay').textContent = avatar;
            document.getElementById('avatarInput').value = '';
        }
    }

    function saveProfile() {
        const name = document.getElementById('profileName').value.trim();
        const bio = document.getElementById('profileBio').value.trim();
        const status = document.getElementById('profileStatus').value;
        const avatar = document.getElementById('profileAvatarDisplay').textContent;

        if (!name) {
            alert('Name cannot be empty');
            return;
        }

        // Update user
        state.currentUser.name = name;
        state.currentUser.avatar = avatar;
        
        // Save profile
        state.userProfiles[state.currentUser.id] = {
            bio,
            status,
            avatar
        };

        // Update user in users list
        const user = state.users.find(u => u.id === state.currentUser.id);
        if (user) {
            user.name = name;
            user.avatar = avatar;
        }

        saveToStorage();
        localStorage.setItem('friendchat_currentUser', JSON.stringify(state.currentUser));
        
        document.getElementById('userAvatarChat').textContent = avatar;
        document.getElementById('chatUserName').textContent = name;
        updateContactsList();

        alert('Profile updated successfully!');
        closeProfileModal();
    }

    // ============ INVITE FUNCTIONS ============
    function openInviteModal() {
        document.getElementById('inviteCode').textContent = generateInviteCode();
        updatePendingRequests();
        document.getElementById('inviteModal').classList.add('active');
    }

    function closeInviteModal() {
        document.getElementById('inviteModal').classList.remove('active');
    }

    function generateInviteCode() {
        return 'FC' + Math.random().toString(36).substr(2, 9).toUpperCase();
    }

    function copyInviteCode() {
        const code = document.getElementById('inviteCode').textContent;
        navigator.clipboard.writeText(code).then(() => {
            alert('Invite code copied! Share it with friends.');
        });
    }

    function searchAndAddFriend() {
        const search = document.getElementById('searchUserInput').value.toLowerCase().trim();
        if (!search) {
            alert('Enter an email or name');
            return;
        }

        const results = state.users.filter(u => 
            u.id !== state.currentUser.id && 
            (u.email.toLowerCase().includes(search) || u.name.toLowerCase().includes(search)) &&
            u.approved
        );

        const resultsHtml = results.length 
            ? results.map(user => `
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px; background: white; border-radius: 6px; margin-bottom: 8px; border-left: 3px solid var(--primary);">
                    <div>
                        <div style="font-weight: 600; color: var(--dark);">${user.name}</div>
                        <div style="font-size: 12px; color: var(--text);">${user.email}</div>
                    </div>
                    <button class="invite-button" onclick="sendFriendRequest(${user.id}, '${user.name}')">Add</button>
                </div>
            `).join('')
            : '<p style="color: var(--text); font-size: 14px;">No users found</p>';

        document.getElementById('searchResults').innerHTML = resultsHtml;
    }

    function sendFriendRequest(userId, userName) {
        if (state.friendRequests.some(req => req.to === userId)) {
            alert('Request already sent to ' + userName);
            return;
        }

        state.friendRequests.push({
            from: state.currentUser.id,
            to: userId,
            fromName: state.currentUser.name,
            status: 'pending'
        });

        saveToStorage();
        alert('Friend request sent to ' + userName);
        document.getElementById('searchUserInput').value = '';
        document.getElementById('searchResults').innerHTML = '';
    }

    function sendEmailInvite() {
        const email = document.getElementById('inviteEmailInput').value.trim();
        if (!email) {
            alert('Enter a valid email address');
            return;
        }

        const inviteCode = document.getElementById('inviteCode').textContent;
        
        state.sentInvites.push({
            email,
            code: inviteCode,
            from: state.currentUser.name,
            sent: new Date().getTime()
        });

        saveToStorage();
        alert(`Invitation sent to ${email}!\n\nInvite Code: ${inviteCode}`);
        document.getElementById('inviteEmailInput').value = '';
    }

    function updatePendingRequests() {
        const incoming = state.friendRequests.filter(req => 
            req.to === state.currentUser.id && req.status === 'pending'
        );

        const requestsHtml = incoming.length
            ? incoming.map(req => `
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px; background: white; border-radius: 6px; margin-bottom: 8px;">
                    <div style="font-weight: 600; color: var(--dark);">${req.fromName}</div>
                    <div style="display: flex; gap: 8px;">
                        <button class="friend-accept-btn friend-request-btn" onclick="acceptFriendRequest(${req.from})">✓</button>
                        <button class="friend-reject-btn friend-request-btn" onclick="rejectFriendRequest(${req.from})">✕</button>
                    </div>
                </div>
            `).join('')
            : '<p style="font-size: 13px; color: var(--text);">No pending requests</p>';

        document.getElementById('pendingRequests').innerHTML = requestsHtml;
    }

    function updateFriendRequests() {
        const incoming = state.friendRequests.filter(req => 
            req.to === state.currentUser.id && req.status === 'pending'
        );

        if (incoming.length === 0) {
            document.getElementById('friendRequests').innerHTML = '';
            return;
        }

        document.getElementById('friendRequests').innerHTML = `
            <div class="friends-request-section">
                <div class="friends-request-title">🔔 Friend Requests</div>
                ${incoming.map(req => `
                    <div class="friend-request-item">
                        <span class="friend-request-name">${req.fromName}</span>
                        <div class="friend-request-actions">
                            <button class="friend-request-btn friend-accept-btn" onclick="acceptFriendRequest(${req.from})">✓</button>
                            <button class="friend-request-btn friend-reject-btn" onclick="rejectFriendRequest(${req.from})">✕</button>
                        </div>
                    </div>
                `).join('')}
            </div>
        `;
    }

    function acceptFriendRequest(fromId) {
        const reqIndex = state.friendRequests.findIndex(req => 
            req.from === fromId && req.to === state.currentUser.id
        );

        if (reqIndex !== -1) {
            state.friendRequests[reqIndex].status = 'accepted';
            saveToStorage();
            updateFriendRequests();
            updateContactsList();
            alert('Friend request accepted!');
        }
    }

    function rejectFriendRequest(fromId) {
        state.friendRequests = state.friendRequests.filter(req => 
            !(req.from === fromId && req.to === state.currentUser.id)
        );
        saveToStorage();
        updateFriendRequests();
        alert('Friend request rejected!');
    }

    // ============ CALL FUNCTIONS - UPDATED ============
    function startCall() {
        if (!state.selectedContact) {
            alert('Select a contact first');
            return;
        }

        // Check if they are friends
        const isFriend = state.friendRequests.some(req => 
            ((req.from === state.currentUser.id && req.to === state.selectedContact.id) ||
             (req.from === state.selectedContact.id && req.to === state.currentUser.id)) &&
            req.status === 'accepted'
        );

        if (!isFriend) {
            alert('You can only call friends. Send a friend request first.');
            return;
        }

        // Show incoming call notification on other user
        state.pendingCalls[state.selectedContact.id] = {
            from: state.currentUser.id,
            fromName: state.currentUser.name
        };

        // Open video modal
        document.getElementById('videoModal').classList.add('active');
        state.callActive = true;

        // Request camera and microphone
        navigator.mediaDevices.getUserMedia({
            audio: true,
            video: true
        })
        .then(stream => {
            state.localStream = stream;
            document.getElementById('localVideo').srcObject = stream;
            document.getElementById('remoteVideo').srcObject = new MediaStream();
            document.getElementById('remoteLabel').textContent = state.selectedContact.name;
        })
        .catch(err => {
            alert('Camera/Microphone access denied: ' + err.message);
            endCall();
        });
    }

    function initiateCall(contactId) {
        const contact = state.users.find(u => u.id === contactId);
        if (contact) {
            selectContact({id: contact.id, name: contact.name, avatar: contact.avatar});
            setTimeout(() => startCall(), 300);
        }
    }

    function showCallNotification(fromName, fromId) {
        document.getElementById('callNotificationHeader').textContent = '☎️ Incoming Call';
        document.getElementById('callNotificationMessage').textContent = `${fromName} is calling...`;
        document.getElementById('callNotification').classList.remove('hidden');
        
        state.pendingCalls['incoming'] = {
            from: fromId,
            fromName: fromName
        };
    }

    function acceptCall() {
        const caller = state.pendingCalls['incoming'];
        if (caller) {
            const contact = state.users.find(u => u.id === caller.from);
            if (contact) {
                selectContact({id: contact.id, name: contact.name, avatar: contact.avatar});
                setTimeout(() => {
                    document.getElementById('videoModal').classList.add('active');
                    state.callActive = true;

                    navigator.mediaDevices.getUserMedia({
                        audio: true,
                        video: true
                    })
                    .then(stream => {
                        state.localStream = stream;
                        document.getElementById('localVideo').srcObject = stream;
                        document.getElementById('remoteLabel').textContent = caller.fromName;
                    })
                    .catch(err => {
                        alert('Camera/Microphone access denied: ' + err.message);
                        endCall();
                    });

                    document.getElementById('callNotification').classList.add('hidden');
                }, 300);
            }
        }
    }

    function declineCall() {
        document.getElementById('callNotification').classList.add('hidden');
        state.pendingCalls['incoming'] = null;
        alert('Call declined');
    }

    // ============ UPDATE CONTACTS LIST ============
    function updateContactsList() {
        // Get friends (accepted friend requests)
        const friends = state.users.filter(u => {
            if (u.id === state.currentUser.id || !u.approved) return false;
            return state.friendRequests.some(req => 
                ((req.from === state.currentUser.id && req.to === u.id) ||
                 (req.from === u.id && req.to === state.currentUser.id)) &&
                req.status === 'accepted'
            );
        });

        document.getElementById('contactsList').innerHTML = friends.length
            ? friends.map(contact => `
                <div class="contact-item ${state.selectedContact?.id === contact.id ? 'active' : ''}" 
                     onclick="selectContact({id: ${contact.id}, name: '${contact.name}', avatar: '${contact.avatar}'})">
                    <div style="flex: 1;">
                        <div class="contact-name">${contact.name}</div>
                        <div class="contact-status">Online</div>
                    </div>
                    <button onclick="event.stopPropagation(); initiateCall(${contact.id})" title="Call" 
                            style="background: var(--primary); color: white; border: none; width: 30px; height: 30px; border-radius: 50%; cursor: pointer; font-size: 14px;">☎️</button>
                </div>
            `).join('')
            : '<p style="color: rgba(255,255,255,0.5); font-size: 13px; padding: 10px;">No friends yet. Send friend requests!</p>';

        updateFriendRequests();
    }

    // Update goToChat to use new functions
    function goToChat() {
        document.getElementById('authPage').classList.add('hidden');
        document.getElementById('chatPage').classList.remove('hidden');
        
        document.getElementById('userAvatarChat').textContent = state.currentUser.avatar;
        document.getElementById('chatUserName').textContent = state.currentUser.name;
        
        updateContactsList();
        updateFriendRequests();
        
        if (state.users.some(u => u.approved && u.id !== state.currentUser.id)) {
            const friend = state.users.find(u => u.approved && u.id !== state.currentUser.id);
            selectContact({id: friend.id, name: friend.name, avatar: friend.avatar});
        }
    }
</script>

</body>
</html>
